{
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "sourceType": "module",
    "ecmaVersion": 2019
  },
  "env": {
    "browser": false,
    "commonjs": true,
    "es6": true,
    "node": true,
    "jest": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "rules": {
    "no-undef": "warn",
    "no-unreachable": "warn",
    "semi": "warn",
    "quotes": ["warn", "single"]
  },
  "overrides": [
    {
      "files": ["test/**/*.ts"],
      "env": {
        "jest": true
      }
    }
  ]
}